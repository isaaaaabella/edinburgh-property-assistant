</nav>
{% endmacro %}


{# === Compact data grid: HR fields at a glance === #}
{% macro meta_grid(record) %}
<section class="meta-grid">
  {% if record.hr_valuation %}
  <div class="cell">
    <div class="label">HR 估价</div>
    <div class="value">£{{ '{:,.0f}'.format(record.hr_valuation) }}</div>
  </div>
  {% endif %}
  {% if record.asking_price %}
  <div class="cell">
    <div class="label">挂牌价</div>
    <div class="value">£{{ '{:,.0f}'.format(record.asking_price) }}</div>
  </div>
  {% endif %}
  {% if record.bedrooms %}
  <div class="cell">
    <div class="label">卧室</div>
    <div class="value">{{ record.bedrooms }}</div>
  </div>
  {% endif %}
  {% if record.floor_area %}
  <div class="cell">
    <div class="label">面积</div>
    <div class="value">{{ record.floor_area }} m²</div>
  </div>
  {% endif %}
  {% if record.floor %}
  <div class="cell">
    <div class="label">楼层</div>
    <div class="value">{{ record.floor }}</div>
  </div>
  {% endif %}
  {% if record.epc_rating %}
  <div class="cell">
    <div class="label">EPC</div>
    <div class="value">{{ record.epc_rating }}{% if record.epc_score %} ({{ record.epc_score }}){% endif %}</div>
  </div>
  {% endif %}
  {% if record.building_type %}
  <div class="cell">
    <div class="label">类型</div>
    <div class="value">{{ record.building_type }}</div>
  </div>
  {% endif %}
  {% if record.era %}
  <div class="cell">
    <div class="label">建造年代</div>
    <div class="value">{{ record.era }}</div>
  </div>
  {% endif %}
  {% if record.cat2_count is not none or record.cat3_count is not none %}
  <div class="cell">
    <div class="label">Cat 2/3</div>
    <div class="value">
      {% if record.cat3_count %}<span style="color:#c53030">{{ record.cat3_count }} Cat 3</span>{% else %}0 Cat 3{% endif %}
      / {{ record.cat2_count or 0 }} Cat 2
    </div>
  </div>
  {% endif %}
  {% if record.factor_status %}
  <div class="cell">
    <div class="label">Factor</div>
    <div class="value">{{ record.factor_status }}{% if record.factor_monthly %} · £{{ record.factor_monthly }}/月{% endif %}</div>
  </div>
  {% endif %}
</section>
{% endmacro %}


{# === Area intelligence: SIMD / flood / commute / schools === #}
{% macro area_intelligence(record, area=None) %}
{% if area or record.school_zone %}
<section class="section" id="area">
  <h3>🗺️ 区域情报</h3>
  {% if area and area.simd %}
    <div class="score-row">
      <div class="label">SIMD 综合分位 — <strong>{{ area.simd.decile }}/10</strong></div>
      <div class="score-bar">
        <div class="score-bar-fill {% if area.simd.decile >= 8 %}full{% elif area.simd.decile < 5 %}low{% endif %}"
             style="width: {{ area.simd.decile * 10 }}%"></div>
      </div>
      <div class="detail">10 = 最富裕；爱丁堡南区典型 8-10</div>
    </div>
  {% endif %}
  {% if area and area.flood %}
    <p style="margin-top:8px;"><strong>洪水风险：</strong>{{ area.flood }}</p>
  {% endif %}
  {% if area and area.commute %}
    <h4 style="margin-top:10px;">通勤时间</h4>
    <ul>
      {% if area.commute.user_min %}<li>用户工作地: {{ area.commute.user_min }} 分钟</li>{% endif %}
      {% if area.commute.partner_min %}<li>伴侣工作地: {{ area.commute.partner_min }} 分钟</li>{% endif %}
    </ul>
  {% endif %}
  {% if record.school_zone %}
    <h4 style="margin-top:10px;">学区</h4>
    <p>{{ record.school_zone | join(' · ') }}</p>
  {% endif %}
</section>
{% endif %}
{% endmacro %}


{# === HR Summary callout: condition snapshot + link to full home_report === #}
{% macro hr_summary(record, parsed=None) %}
<section class="section" id="hr-summary">
  <h3>📄 Home Report 速览</h3>
  <p style="font-size:13px;color:#4a5568;margin-bottom:10px;">
    这套房子的官方 Home Report 给出以下关键判断（解析自 PDF，未经我们二次加工）：
  </p>
  <ul style="font-size:13.5px;line-height:1.7;">
    {% if record.hr_valuation %}
      <li><strong>市场估价</strong>：£{{ '{:,.0f}'.format(record.hr_valuation) }}
        {% if record.asking_price and record.asking_price != record.hr_valuation %}
          （挂牌 £{{ '{:,.0f}'.format(record.asking_price) }}，差 {{ '%+.1f'|format((record.asking_price - record.hr_valuation) / record.hr_valuation * 100) }}%）
        {% endif %}
      </li>
    {% endif %}
    {% if record.cat3_count is not none or record.cat2_count is not none %}
      <li><strong>状况评级</strong>：
        {% if record.cat3_count %}<span style="color:#c53030;">{{ record.cat3_count }} 个 Cat 3（需立即处理）</span> · {% endif %}
        {{ record.cat2_count or 0 }} 个 Cat 2（需关注） · 其余 Cat 1
        {% if record.roof_issue %} · <span style="color:#d97706;">屋顶被标记</span>{% endif %}
      </li>
    {% endif %}
    {% if record.epc_rating %}
      <li><strong>能效</strong>：EPC {{ record.epc_rating }}{% if record.epc_score %} ({{ record.epc_score }}/100){% endif %}{% if record.gas_heating %} · Gas 中央供暖{% endif %}</li>
    {% endif %}
    {% if record.factor_status %}
      <li><strong>物业管理</strong>：{{ record.factor_status }}{% if record.factor_monthly %} · £{{ record.factor_monthly }}/月{% endif %}{% if not record.building_insurance %} · 公共建筑保险需自购{% endif %}</li>
    {% endif %}
    {% if record.ownership_years %}
      <li><strong>屋主持有</strong>：{{ record.ownership_years }} 年</li>
    {% endif %}
  </ul>

  {% set concerning = (parsed.condition_table or []) | selectattr('cat', 'in', ['2','3']) | list %}
  {% if concerning %}
  <h4 style="margin-top:12px;">⚠️ 测量员标记的具体项（{{ concerning|length }} 项）</h4>
  <ul style="font-size:12.5px;line-height:1.6;">
    {% for row in concerning[:6] %}
      <li>
        <span class="cat-pill cat{{ row.cat }}">Cat {{ row.cat }}</span>
        <strong>{{ row.row }}</strong>
        <span class="page-ref">p.{{ row.page }}</span>
        — <small>{{ row.notes }}</small>
      </li>
    {% endfor %}
    {% if concerning|length > 6 %}
      <li><small>……还有 {{ concerning|length - 6 }} 项，看 Cat 表完整列表</small></li>
    {% endif %}
  </ul>
  {% endif %}

  {% if record.pdf_path %}
  <p style="margin-top:12px;">
    <a class="link-chip" href="file://{{ record.pdf_path }}" target="_blank" rel="noopener">
      📄 打开原始 Home Report PDF
    </a>
  </p>
  {% endif %}
</section>
{% endmacro %}


{# === Location card: embedded map + external links === #}
{% macro location_card(record) %}
{% set map_query = record.postcode or record.address %}
{% if map_query or record.listing_url %}
<div class="location-card">
  {% if map_query %}
  <iframe
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    src="https://maps.google.com/maps?q={{ map_query|urlencode }}&t=&z=15&ie=UTF8&iwloc=&output=embed"
    title="Map of {{ record.address }}"></iframe>
  {% endif %}
  <div class="link-chips">
    {% if map_query %}
      <a class="link-chip primary" target="_blank" rel="noopener"
         href="https://www.google.com/maps/search/?api=1&query={{ map_query|urlencode }}">
        🗺️ Open in Maps
      </a>
    {% endif %}
    {% if record.listing_url %}
      <a class="link-chip" target="_blank" rel="noopener" href="{{ record.listing_url }}">
        🏠 {% if 'rightmove' in record.listing_url %}Rightmove{% elif 'espc' in record.listing_url %}ESPC{% else %}房源链接{% endif %}
      </a>
    {% endif %}
    {% if record.postcode %}
      <a class="link-chip" target="_blank" rel="noopener"
         href="https://www.scotlandscensus.gov.uk/search-the-census#/explore/find-area?postcode={{ record.postcode|urlencode }}">
        📊 SIMD
      </a>
    {% endif %}
  </div>
</div>
{% endif %}
{% endmacro %}


{# === Score badge for header === #}
{% macro score_badge(score) %}
{% if score >= 80 %}
  <div class="score-badge s-high">{{ score|int }}</div>
{% elif score >= 45 %}
  <div class="score-badge s-mid">{{ score|int }}</div>
{% else %}
  <div class="score-badge s-low">{{ score|int }}</div>
{% endif %}
{% endmacro %}


{# === Score breakdown (7 bars), with optional opinion to show corrections === #}
{% macro score_breakdown(breakdown, opinion=None) %}
{% set ns = namespace(delta=0) %}
{% if opinion and opinion.score_corrections %}
  {% for f in opinion.score_corrections if f.score_delta %}
    {% set ns.delta = ns.delta + f.score_delta %}
  {% endfor %}
{% endif %}
{% set total_delta = ns.delta %}
<section class="section" id="scoring">
  <h3>📊 评分详情</h3>
  {% for d in breakdown.dimensions %}
    {% set pct = (d.score / d.max_score * 100) if d.max_score else 0 %}
    <div class="score-row">
      <div class="label">{{ d.name }} —
        <span style="color:{% if d.score >= d.max_score * 0.7 %}#38a169{% elif d.score < 0 %}#c53030{% else %}#d69e2e{% endif %}">{{ '%g'|format(d.score) }}</span>
        / {{ '%g'|format(d.max_score) }}
      </div>
      <div class="score-bar">
        <div class="score-bar-fill {% if pct >= 90 %}full{% elif pct < 30 %}low{% endif %}"
             style="width: {{ pct|int|abs }}%"></div>
      </div>
      <div class="detail">{{ d.detail }}</div>
    </div>
  {% endfor %}
  <p style="text-align:right; margin-top:10px; font-size:14px;">
    总分 <strong style="font-size:18px;">{{ breakdown.total }}</strong> / 100
    {% if total_delta %}
      <span class="total-corrected">⚡ 评估师调整 {{ '%+.1f'|format(total_delta) }} → {{ '%g'|format(breakdown.total + total_delta) }}</span>
    {% endif %}
    <br>{{ breakdown.recommendation }}
  </p>
  {% if total_delta %}
  <p style="margin-top:6px; font-size:12px; color:#718096;">
    括号内为机械评分；评估师基于 <a href="#opinion-2" style="color:#2c5282;">② 评分校正</a> 给出修正建议。
  </p>
  {% endif %}
</section>
{% endmacro %}


{# === Cat 2 / Cat 3 table === #}
{% macro condition_table(condition_rows) %}
<section class="section" id="condition">
  <h3>🔎 Condition 表</h3>
  <table class="cat-table">
    <thead><tr><th>项目</th><th>Cat</th><th>p.</th><th>Notes</th></tr></thead>
    <tbody>
    {% for row in condition_rows %}
      {% if row.cat in ('2', '3') %}
      <tr>
        <td>{{ row.row }}</td>
        <td><span class="cat-pill cat{{ row.cat }}">Cat {{ row.cat }}</span></td>
        <td><small>p.{{ row.page }}</small></td>
        <td><small>{{ row.notes }}</small></td>
      </tr>
      {% endif %}
    {% endfor %}
    </tbody>
  </table>
</section>
{% endmacro %}
