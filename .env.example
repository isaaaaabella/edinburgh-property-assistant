# Scottish Property Assistant — environment template
# Copy to .env and fill in only what you actually use.
# Never commit .env to git (it's in .gitignore).

# === REQUIRED ===
# Storage backend: 'local' (zero-config, ~/.property_data/) or 'notion'
STORAGE_BACKEND=local

# === OPTIONAL: Notion (only if STORAGE_BACKEND=notion) ===
# Get token at https://www.notion.so/profile/integrations
# NOTION_TOKEN=secret_xxx
# NOTION_PROPERTY_DB_ID=<32-char-uuid-of-your-property-database>

# === OPTIONAL: Gmail (for /property emails intake) ===
# Use a Gmail App Password, not your account password:
# https://myaccount.google.com/apppasswords
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# === OPTIONAL: Google Maps Directions API (for commute times) ===
# Without this, area_data falls back to postcode-distance heuristics.
# Enable at https://console.cloud.google.com/ → enable Directions API
# GOOGLE_MAPS_API_KEY=AIza...

# === OPTIONAL: where to store property data (LocalJSONStorage) ===
# Defaults to ~/.property_data/. Override if you want a different location.
# PROPERTY_DATA_DIR=/Users/you/Dropbox/property_data
